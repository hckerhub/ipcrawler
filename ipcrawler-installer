# Install modern web discovery tools
install_web_discovery_tools() {
    print_status "Installing modern web discovery tools..."
    
    # Directory/File Discovery Tools
    print_info "Installing directory discovery tools..."
    
    # ffuf (Go-based, fastest)
    if command_exists ffuf; then
        print_success "ffuf is already installed"
    else
        case $DISTRO in
            debian)
                # Try apt first
                if sudo apt-get install -y ffuf 2>/dev/null; then
                    print_success "ffuf installed via apt"
                else
                    install_go_tool "github.com/ffuf/ffuf/v2@latest" "ffuf"
                fi
                ;;
            macos)
                install_package "ffuf" "ffuf"
                ;;
            *)
                install_go_tool "github.com/ffuf/ffuf/v2@latest" "ffuf"
                ;;
        esac
    fi
    
    # feroxbuster (Rust-based, very fast)
    if command_exists feroxbuster; then
        print_success "feroxbuster is already installed"
    else
        case $DISTRO in
            debian)
                # Try apt first
                if sudo apt-get install -y feroxbuster 2>/dev/null; then
                    print_success "feroxbuster installed via apt"
                else
                    print_info "Installing feroxbuster from GitHub releases..."
                    wget -q https://github.com/epi052/feroxbuster/releases/latest/download/x86_64-linux-feroxbuster.tar.gz -O /tmp/feroxbuster.tar.gz
                    tar -xzf /tmp/feroxbuster.tar.gz -C /tmp/
                    sudo mv /tmp/feroxbuster /usr/local/bin/
                    sudo chmod +x /usr/local/bin/feroxbuster
                    rm /tmp/feroxbuster.tar.gz
                fi
                ;;
            macos)
                install_package "feroxbuster" "feroxbuster"
                ;;
            *)
                print_info "Please install feroxbuster manually from: https://github.com/epi052/feroxbuster"
                ;;
        esac
    fi
    
    # gobuster (Go-based, reliable)
    if command_exists gobuster; then
        print_success "gobuster is already installed"
    else
        case $DISTRO in
            debian)
                install_package "gobuster" "gobuster"
                ;;
            macos)
                install_package "gobuster" "gobuster"
                ;;
            *)
                install_go_tool "github.com/OJ/gobuster/v3@latest" "gobuster"
                ;;
        esac
    fi
    
    # Install wordlists
    print_status "Installing wordlists..."
    case $DISTRO in
        debian)
            install_package "dirb" "dirb (includes wordlists)"
            install_package "dirbuster" "dirbuster (includes wordlists)"
            # Try to install seclists
            if sudo apt-get install -y seclists 2>/dev/null; then
                print_success "SecLists installed via apt"
            else
                print_info "Installing SecLists manually..."
                if [[ ! -d "/usr/share/seclists" ]]; then
                    sudo git clone https://github.com/danielmiessler/SecLists.git /usr/share/seclists
                fi
            fi
            ;;
        macos)
            # Install wordlists manually for macOS since dirb package issues exist
            print_info "Installing wordlists manually..."
            if [[ ! -d "./wordlists/dirb" ]]; then
                mkdir -p ./wordlists/dirb
                curl -s -L https://raw.githubusercontent.com/v0re/dirb/master/wordlists/common.txt -o ./wordlists/dirb/common.txt
                curl -s -L https://raw.githubusercontent.com/v0re/dirb/master/wordlists/small.txt -o ./wordlists/dirb/small.txt
                curl -s -L https://raw.githubusercontent.com/v0re/dirb/master/wordlists/big.txt -o ./wordlists/dirb/big.txt
                print_success "DIRB wordlists downloaded to ./wordlists/dirb/"
            else
                print_success "DIRB wordlists already available"
            fi
            
            # Download SecLists
            if [[ ! -d "./wordlists/SecLists" ]]; then
                print_info "Downloading SecLists..."
                git clone --depth 1 https://github.com/danielmiessler/SecLists.git ./wordlists/SecLists
                print_success "SecLists cloned to ./wordlists/SecLists/"
            else
                print_success "SecLists already available"
            fi
            ;;
        *)
            # Generic installation for other platforms
            print_info "Installing wordlists manually..."
            mkdir -p ./wordlists/dirb
            if command_exists curl; then
                curl -s -L https://raw.githubusercontent.com/v0re/dirb/master/wordlists/common.txt -o ./wordlists/dirb/common.txt
                curl -s -L https://raw.githubusercontent.com/v0re/dirb/master/wordlists/small.txt -o ./wordlists/dirb/small.txt
                print_success "Basic wordlists downloaded"
            fi
            ;;
    esac
}


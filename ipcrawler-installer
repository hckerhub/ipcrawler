#!/bin/bash

# IPCrawler Enhanced Installer - Complete Penetration Testing Tool Setup
# Installs all modern web discovery and reconnaissance tools

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Function to print colored output
print_header() {
    echo -e "${PURPLE}
╔══════════════════════════════════════════╗
║        IPCrawler Enhanced Installer       ║
║     Modern Penetration Testing Suite     ║
╚══════════════════════════════════════════╝${NC}"
}

print_status() {
    echo -e "${BLUE}[INSTALLER]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[INSTALLER]${NC} ✓ $1"
}

print_warning() {
    echo -e "${YELLOW}[INSTALLER]${NC} ⚠ $1"
}

print_error() {
    echo -e "${RED}[INSTALLER]${NC} ✗ $1"
}

print_info() {
    echo -e "${CYAN}[INFO]${NC} $1"
}

# Detect OS
detect_os() {
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        OS="linux"
        if command -v apt-get &> /dev/null; then
            DISTRO="debian"
        elif command -v yum &> /dev/null; then
            DISTRO="redhat"
        elif command -v pacman &> /dev/null; then
            DISTRO="arch"
        else
            DISTRO="unknown"
        fi
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        OS="macos"
        DISTRO="macos"
    elif [[ "$OSTYPE" == "cygwin" ]] || [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "win32" ]]; then
        OS="windows"
        DISTRO="windows"
    else
        OS="unknown"
        DISTRO="unknown"
    fi
}

# Check if command exists
command_exists() {
    command -v "$1" &> /dev/null
}

# Install package based on OS
install_package() {
    local package=$1
    local package_name=${2:-$package}
    
    print_status "Installing $package_name..."
    
    case $DISTRO in
        debian)
            sudo apt-get update &> /dev/null
            sudo apt-get install -y $package
            ;;
        redhat)
            sudo yum install -y $package
            ;;
        arch)
            sudo pacman -S --noconfirm $package
            ;;
        macos)
            if command_exists brew; then
                brew install $package
            else
                print_error "Homebrew not found. Please install Homebrew first: https://brew.sh"
                return 1
            fi
            ;;
        *)
            print_error "Unsupported OS/distribution for automatic installation"
            print_info "Please manually install: $package_name"
            return 1
            ;;
    esac
}

# Install with pip3
install_pip3_package() {
    local package=$1
    local package_name=${2:-$package}
    
    print_status "Installing $package_name via pip3..."
    
    case $DISTRO in
        macos)
            # Handle macOS externally managed environment
            if command_exists pipx; then
                print_info "Using pipx to install $package_name..."
                if pipx install $package; then
                    print_success "$package_name installed successfully via pipx"
                else
                    print_warning "pipx failed, trying pip3 with --user flag..."
                    if pip3 install --user --break-system-packages $package; then
                        print_success "$package_name installed via pip3 --user"
                    else
                        print_warning "Failed to install $package_name"
                        print_info "You may need to install manually: pip3 install --user --break-system-packages $package"
                    fi
                fi
            else
                print_info "Installing pipx first..."
                if brew install pipx; then
                    pipx install $package
                    print_success "$package_name installed via pipx"
                else
                    print_warning "pipx not available, using pip3 with --user flag..."
                    if pip3 install --user --break-system-packages $package; then
                        print_success "$package_name installed via pip3 --user"
                    else
                        print_warning "Failed to install $package_name"
                        print_info "You may need to install manually: pip3 install --user --break-system-packages $package"
                    fi
                fi
            fi
            ;;
        *)
            # Standard pip installation for other platforms
            if command_exists pip3; then
                pip3 install --user $package
            elif command_exists pip; then
                pip install --user $package
            else
                print_error "pip3/pip not found. Installing python3-pip..."
                install_package "python3-pip" "Python3 pip"
                pip3 install --user $package
            fi
            ;;
    esac
}

# Install Go tools
install_go_tool() {
    local tool_url=$1
    local tool_name=$2
    
    print_status "Installing $tool_name via Go..."
    
    if command_exists go; then
        go install $tool_url
    else
        print_error "Go not found. Please install Go first."
        return 1
    fi
}

# Install recon-ng from source
install_recon_ng_from_source() {
    print_status "Installing recon-ng from GitHub source..."
    
    local install_dir="/opt/recon-ng"
    local bin_link="/usr/local/bin/recon-ng"
    
    # Check if we have sudo access for system installation
    if [[ $EUID -eq 0 ]] || sudo -n true 2>/dev/null; then
        # System-wide installation
        if [[ -d "$install_dir" ]]; then
            print_info "Removing existing recon-ng installation..."
            sudo rm -rf "$install_dir"
        fi
        
        print_info "Cloning recon-ng repository..."
        if sudo git clone https://github.com/lanmaster53/recon-ng.git "$install_dir"; then
            print_info "Installing Python requirements..."
            cd "$install_dir"
            
            # Install requirements using the same method as other Python packages
            if [[ "$OS" == "Darwin" ]] && command_exists pipx; then
                # For macOS, install requirements individually via pipx
                sudo pipx install requests 2>/dev/null || true
                sudo pipx install beautifulsoup4 2>/dev/null || true
                sudo pipx install lxml 2>/dev/null || true
                sudo pipx install PyYAML 2>/dev/null || true
                sudo pipx install mechanize 2>/dev/null || true
            else
                # Try pip3 installation
                sudo pip3 install -r requirements.txt 2>/dev/null || \
                sudo pip3 install --user -r requirements.txt 2>/dev/null || \
                sudo pip3 install --break-system-packages -r requirements.txt 2>/dev/null || \
                print_warning "Could not install all Python requirements. Manual installation may be needed."
            fi
            
            # Create executable symlink
            sudo chmod +x "$install_dir/recon-ng"
            if [[ ! -L "$bin_link" ]]; then
                sudo ln -s "$install_dir/recon-ng" "$bin_link"
            fi
            
            cd - > /dev/null
            print_success "recon-ng installed from source to $install_dir"
        else
            print_warning "Failed to clone recon-ng repository"
        fi
    else
        # User installation fallback
        local user_install_dir="$HOME/.local/share/recon-ng"
        local user_bin_dir="$HOME/.local/bin"
        
        mkdir -p "$user_bin_dir"
        
        if [[ -d "$user_install_dir" ]]; then
            print_info "Removing existing recon-ng installation..."
            rm -rf "$user_install_dir"
        fi
        
        print_info "Cloning recon-ng repository to user directory..."
        if git clone https://github.com/lanmaster53/recon-ng.git "$user_install_dir"; then
            print_info "Installing Python requirements..."
            cd "$user_install_dir"
            
            # Install requirements for user
            pip3 install --user -r requirements.txt 2>/dev/null || \
            pip3 install --user --break-system-packages -r requirements.txt 2>/dev/null || \
            print_warning "Could not install all Python requirements. Manual installation may be needed."
            
            # Create executable symlink
            chmod +x "$user_install_dir/recon-ng"
            ln -sf "$user_install_dir/recon-ng" "$user_bin_dir/recon-ng"
            
            cd - > /dev/null
            print_success "recon-ng installed from source to $user_install_dir"
            print_info "Make sure $user_bin_dir is in your PATH"
        else
            print_warning "Failed to clone recon-ng repository"
        fi
    fi
}

# Check and install Go
check_go() {
    print_status "Checking Go installation..."
    if command_exists go; then
        local go_version=$(go version | cut -d' ' -f3)
        print_success "Go is installed ($go_version)"
    else
        print_warning "Go is not installed"
        print_info "Installing Go..."
        case $DISTRO in
            debian)
                install_package "golang-go" "Go Programming Language"
                ;;
            macos)
                install_package "go" "Go Programming Language"
                ;;
            *)
                print_info "Please install Go from: https://golang.org/dl/"
                print_info "Required Go version: 1.21 or higher"
                return 1
                ;;
        esac
    fi
}

# Check and install nmap
check_nmap() {
    print_status "Checking nmap installation..."
    if command_exists nmap; then
        local nmap_version=$(nmap --version | head -n1 | cut -d' ' -f3)
        print_success "nmap is installed ($nmap_version)"
    else
        print_warning "nmap is not installed"
        install_package "nmap" "Nmap Network Scanner"
    fi
}


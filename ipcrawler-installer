#!/bin/bash

# IPCrawler Installer - System Check and Tool Installation
# Checks for required tools and installs missing dependencies

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

# Function to print colored output
print_header() {
    echo -e "${PURPLE}
╔══════════════════════════════════════════╗
║           IPCrawler Installer            ║
║      Penetration Testing Tool Setup      ║
╚══════════════════════════════════════════╝${NC}"
}

print_status() {
    echo -e "${BLUE}[INSTALLER]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[INSTALLER]${NC} ✓ $1"
}

print_warning() {
    echo -e "${YELLOW}[INSTALLER]${NC} ⚠ $1"
}

print_error() {
    echo -e "${RED}[INSTALLER]${NC} ✗ $1"
}

print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

# Detect OS
detect_os() {
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        OS="linux"
        if command -v apt-get &> /dev/null; then
            DISTRO="debian"
        elif command -v yum &> /dev/null; then
            DISTRO="redhat"
        elif command -v pacman &> /dev/null; then
            DISTRO="arch"
        else
            DISTRO="unknown"
        fi
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        OS="macos"
        DISTRO="macos"
    elif [[ "$OSTYPE" == "cygwin" ]] || [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "win32" ]]; then
        OS="windows"
        DISTRO="windows"
    else
        OS="unknown"
        DISTRO="unknown"
    fi
}

# Check if command exists
command_exists() {
    command -v "$1" &> /dev/null
}

# Install package based on OS
install_package() {
    local package=$1
    local package_name=${2:-$package}
    
    print_status "Installing $package_name..."
    
    case $DISTRO in
        debian)
            sudo apt-get update &> /dev/null
            sudo apt-get install -y $package
            ;;
        redhat)
            sudo yum install -y $package
            ;;
        arch)
            sudo pacman -S --noconfirm $package
            ;;
        macos)
            if command_exists brew; then
                brew install $package
            else
                print_error "Homebrew not found. Please install Homebrew first: https://brew.sh"
                return 1
            fi
            ;;
        *)
            print_error "Unsupported OS/distribution for automatic installation"
            print_info "Please manually install: $package_name"
            return 1
            ;;
    esac
}

# Check and install Go
check_go() {
    print_status "Checking Go installation..."
    if command_exists go; then
        local go_version=$(go version | cut -d' ' -f3)
        print_success "Go is installed ($go_version)"
    else
        print_warning "Go is not installed"
        print_info "Please install Go from: https://golang.org/dl/"
        print_info "Required Go version: 1.21 or higher"
        return 1
    fi
}

# Check and install nmap
check_nmap() {
    print_status "Checking nmap installation..."
    if command_exists nmap; then
        local nmap_version=$(nmap --version | head -n1 | cut -d' ' -f3)
        print_success "nmap is installed ($nmap_version)"
    else
        print_warning "nmap is not installed"
        install_package "nmap" "Nmap Network Scanner"
    fi
}

# Check and install whatweb
check_whatweb() {
    print_status "Checking whatweb installation..."
    if command_exists whatweb; then
        print_success "whatweb is installed"
    else
        print_warning "whatweb is not installed"
        case $DISTRO in
            debian)
                install_package "whatweb" "WhatWeb"
                ;;
            macos)
                install_package "whatweb" "WhatWeb"
                ;;
            *)
                print_info "Please install whatweb manually: https://github.com/urbanadventurer/WhatWeb"
                ;;
        esac
    fi
}

# Check additional tools
check_additional_tools() {
    print_status "Checking additional penetration testing tools..."
    
    # Check for curl
    if command_exists curl; then
        print_success "curl is available"
    else
        print_warning "curl is not installed"
        install_package "curl" "cURL"
    fi
    
    # Check for wget
    if command_exists wget; then
        print_success "wget is available"
    else
        print_warning "wget is not installed"
        install_package "wget" "Wget"
    fi
    
    # Check for dig
    if command_exists dig; then
        print_success "dig is available"
    else
        print_warning "dig is not installed"
        case $DISTRO in
            debian)
                install_package "dnsutils" "DNS utilities (dig)"
                ;;
            macos)
                install_package "bind" "DNS utilities (dig)"
                ;;
            *)
                print_info "Please install dig (DNS utilities)"
                ;;
        esac
    fi
}

# Create bin directory
create_directories() {
    print_status "Creating necessary directories..."
    mkdir -p bin
    mkdir -p logs
    print_success "Directories created"
}

# Setup Go dependencies
setup_go_dependencies() {
    print_status "Setting up Go dependencies..."
    
    # Check if we're in the correct directory
    if [[ ! -f "main.go" ]]; then
        print_error "main.go not found. Please run this script from the project root directory."
        exit 1
    fi
    
    # Download and verify dependencies
    print_status "Downloading Go modules..."
    go mod download
    
    print_status "Verifying Go modules..."
    go mod verify
    
    print_status "Tidying Go modules..."
    go mod tidy
    
    print_success "Go dependencies setup complete"
}

# Make scripts executable
make_executable() {
    print_status "Setting executable permissions..."
    chmod +x ipcrawler
    chmod +x ipcrawler-installer
    print_success "Scripts are now executable"
}

# Main installation process
main() {
    print_header
    
    print_status "Starting system check and tool installation..."
    
    detect_os
    print_info "Detected OS: $OS ($DISTRO)"
    
    # Check and install required tools
    check_go
    check_nmap
    check_whatweb
    check_additional_tools
    
    # Setup project
    create_directories
    setup_go_dependencies
    make_executable
    
    print_success "Installation completed!"
    print_info "You can now run: ./ipcrawler"
    
    echo -e "${GREEN}
╔══════════════════════════════════════════╗
║        Installation Successful!         ║
║                                          ║
║  Run './ipcrawler' to start the tool     ║
╚══════════════════════════════════════════╝${NC}"
}

# Run main function
main "$@" 
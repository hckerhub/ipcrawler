    mkdir -p logs
    mkdir -p wordlists
    print_success "Directories created"
}

# Setup Go dependencies
setup_go_dependencies() {
    print_status "Setting up Go dependencies..."
    
    # Check if we're in the correct directory
    if [[ ! -f "main.go" ]]; then
        print_error "main.go not found. Please run this script from the project root directory."
        exit 1
    fi
    
    # Download and verify dependencies
    print_status "Downloading Go modules..."
    go mod download
    
    print_status "Verifying Go modules..."
    go mod verify
    
    print_status "Tidying Go modules..."
    go mod tidy
    
    print_success "Go dependencies setup complete"
}

# Create sudo wrapper
create_sudo_wrapper() {
    print_status "Creating sudo wrapper for privileged scans..."
    
    cat > ipcrawler << 'EOF'
#!/bin/bash

# IPCrawler Sudo Wrapper - Automatically runs with required privileges
# This ensures aggressive mode works properly with advanced nmap features

print_banner() {
    echo -e "\033[0;35m
╔══════════════════════════════════════════╗
║              🎯 IPCrawler 2.0             ║
║        Enhanced Reconnaissance Tool       ║
╚══════════════════════════════════════════╝\033[0m"
}

# Check if we need to run with sudo
if [[ $EUID -ne 0 ]]; then
    print_banner
    echo -e "\033[0;33m[INFO]\033[0m IPCrawler requires sudo privileges for advanced scanning features"
    echo -e "\033[0;33m[INFO]\033[0m Restarting with sudo..."
    echo ""
    
    # Re-run with sudo, preserving the current working directory
    exec sudo -E "$0" "$@"
fi

# We're running as root now, execute the actual program
print_banner
echo -e "\033[0;32m[INFO]\033[0m Running with required privileges"
echo -e "\033[0;32m[INFO]\033[0m Advanced scanning features enabled"
echo ""

# Build if needed
if [[ ! -f "./ipcrawler-bin" ]] || [[ "main.go" -nt "./ipcrawler-bin" ]]; then
    echo -e "\033[0;34m[BUILD]\033[0m Building IPCrawler..."
    go build -o ipcrawler-bin .
    echo -e "\033[0;32m[BUILD]\033[0m Build complete"
    echo ""
fi

# Execute the binary
exec ./ipcrawler-bin "$@"
EOF

    chmod +x ipcrawler
    print_success "Sudo wrapper created"
}


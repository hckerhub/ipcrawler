    fi
    
    # recon-ng (Web reconnaissance framework)
    if command_exists recon-ng; then
        print_success "recon-ng is already installed"
    else
        print_warning "recon-ng is not installed"
        print_info "Installing recon-ng from GitHub..."
        case $DISTRO in
            debian)
                # Try apt first for newer distributions
                if sudo apt-get install -y recon-ng 2>/dev/null; then
                    print_success "recon-ng installed via apt"
                else

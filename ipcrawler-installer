                if command_exists brew && brew install recon-ng 2>/dev/null; then
                    print_success "recon-ng installed via Homebrew"
                else
                    install_recon_ng_from_source
                fi
                ;;
            *)
                install_recon_ng_from_source
                ;;
        esac
    fi
    
    print_info "📋 Remember to configure API keys for enhanced functionality:"
    print_info "  • Censys API key: https://search.censys.io/account/api"
    print_info "  • SecurityTrails API key: https://securitytrails.com/corp/api"
}


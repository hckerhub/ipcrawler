# Main installation process
main() {
    print_header
    
    print_status "Starting enhanced tool installation..."
    
    detect_os
    print_info "Detected OS: $OS ($DISTRO)"
    
    # Check and install core requirements
    check_go
    check_nmap
    check_python_tools
    check_additional_tools
    
    # Install modern tools
    install_web_discovery_tools
    install_subdomain_tools
    install_reconnaissance_tools
    install_tech_detection_tools
    
    # Setup project
    create_directories
    setup_go_dependencies
    create_sudo_wrapper
    make_executable
    
    display_summary
}

# Run main function
main "$@" 
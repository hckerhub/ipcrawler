# =============================================================================
# IPCrawler .gitignore - Comprehensive exclusion rules
# =============================================================================

# -----------------------------------------------------------------------------
# Build Artifacts & Binaries
# -----------------------------------------------------------------------------
# Main binary
ipcrawler
ipcrawler.exe

# Platform-specific binaries
ipcrawler-*
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build directories
dist/
build/
target/
bin/

# Go build cache
go-build/

# -----------------------------------------------------------------------------
# Go Language Specific
# -----------------------------------------------------------------------------
# Go modules cache
.cache/
go.work
go.work.sum

# Test coverage
*.out
coverage.html
coverage.xml
*.coverprofile

# Test binaries
*.test
*.test.exe

# Benchmarks
*.bench

# Go vendor (if used)
vendor/

# -----------------------------------------------------------------------------
# Development Tools & IDEs
# -----------------------------------------------------------------------------
# VSCode
.vscode/
*.code-workspace

# JetBrains (GoLand, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Vim/Neovim
*.swp
*.swo
*.swn
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Visual Studio
.vs/

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Logs & Runtime Data
# -----------------------------------------------------------------------------
# Log files
*.log
*.log.*
logs/
log/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Process dumps
*.prof
*.heap

# -----------------------------------------------------------------------------
# Temporary & Cache Directories
# -----------------------------------------------------------------------------
# Temporary folders
tmp/
temp/
.tmp/
.temp/

# Cache directories
.cache/
cache/
.ccache/

# Air live reload
tmp/
.air/

# -----------------------------------------------------------------------------
# Configuration & Secrets
# -----------------------------------------------------------------------------
# Environment files
.env
.env.local
.env.*.local
*.env

# Local configuration
config.local.yaml
config.local.yml
config.local.json
local.yaml
local.yml
local.json

# Secrets and credentials
secrets/
.secrets/
credentials/
.credentials/
*.key
*.pem
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Scan Results & Output
# -----------------------------------------------------------------------------
# Scan output files
scans/
results/
output/

# Data files (optional - uncomment if you don't want to track these)
# *.json
# *.xml
# *.csv
# *.txt
# *.dat

# Reports
reports/
# *.pdf
# *.html
# *.docx

# -----------------------------------------------------------------------------
# Dependencies & Package Managers
# -----------------------------------------------------------------------------
# Node.js (if used for tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Python (if used for scripts)
__pycache__/
*.py[cod]
*$py.class
.Python
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Docker & Containers
# -----------------------------------------------------------------------------
# Docker
.dockerignore
Dockerfile.local
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Security & Penetration Testing
# -----------------------------------------------------------------------------
# Metasploit
.msf4/
*.rc

# Nmap files
*.nmap
*.gnmap
*.xml.nmap

# Wordlists (large files)
wordlists/
*.txt.gz

# -----------------------------------------------------------------------------
# Backup & Archive Files
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old
*.orig
*.rej
*.save
*.tmp

# Archives
*.tar
*.tar.gz
*.tgz
*.zip
*.rar
*.7z

# -----------------------------------------------------------------------------
# Generated Documentation
# -----------------------------------------------------------------------------
docs/generated/
doc/generated/
# *.html
# *.pdf
site/

# -----------------------------------------------------------------------------
# Project-specific Exclusions
# -----------------------------------------------------------------------------
# IPCrawler specific
misc/
tools/external/
config/profiles/

# Database files
*.db
*.sqlite
*.sqlite3

# Binary data
*.bin
*.dat
*.dump 
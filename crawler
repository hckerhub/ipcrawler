#!/bin/bash

# IPCrawler Quick Launch Script v0.1
# Advanced IP Scanner & Vulnerability Hunter for Hack The Box
# Author: hckerhub (https://github.com/hckerhub)
# Usage: ./crawler [IP] [options]
# This script intelligently builds, installs, and runs IPCrawler

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY_NAME="ipcrawler"
LOCAL_BINARY="$SCRIPT_DIR/$BINARY_NAME"
SYSTEM_BINARY="/usr/local/bin/$BINARY_NAME"

# Function to build local binary
build_binary() {
    echo "🔨 Building latest IPCrawler..."
    cd "$SCRIPT_DIR"
    if go build -o "$BINARY_NAME" .; then
        echo "✅ Build complete"
        return 0
    else
        echo "❌ Build failed"
        return 1
    fi
}

# Function to install to system PATH
install_system_binary() {
    if [[ -f "$LOCAL_BINARY" ]]; then
        echo "📦 Installing to system PATH..."
        if sudo cp "$LOCAL_BINARY" "$SYSTEM_BINARY" 2>/dev/null && sudo chmod +x "$SYSTEM_BINARY" 2>/dev/null; then
            echo "✅ System installation complete"
            return 0
        else
            echo "⚠️  Could not install to system PATH (permission denied)"
            echo "📋 Will use local binary instead"
            return 1
        fi
    fi
    return 1
}

# Function to check if system binary is newer than source
is_system_binary_current() {
    if [[ -f "$SYSTEM_BINARY" && -f "$LOCAL_BINARY" ]]; then
        # Compare modification times
        if [[ "$SYSTEM_BINARY" -nt "$LOCAL_BINARY" ]] || [[ "$SYSTEM_BINARY" -ef "$LOCAL_BINARY" ]]; then
            return 0
        fi
    fi
    return 1
}

# Function to run the binary
run_binary() {
    local binary_path="$1"
    shift
    echo "🚀 Running IPCrawler: $binary_path"
    exec "$binary_path" "$@"
}

# Main logic
echo "🔍 Setting up IPCrawler..."

# Always build the latest version
if ! build_binary; then
    echo "❌ Could not build IPCrawler"
    exit 1
fi

# Try to install to system PATH for convenience
install_system_binary

# Use system binary if available and current, otherwise use local
if [[ -f "$SYSTEM_BINARY" ]] && is_system_binary_current; then
    echo "✅ Using system installation"
    run_binary "$SYSTEM_BINARY" "$@"
elif [[ -f "$LOCAL_BINARY" ]]; then
    echo "✅ Using local build"
    run_binary "$LOCAL_BINARY" "$@"
else
    echo "❌ No binary found"
    exit 1
fi 
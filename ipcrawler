#!/bin/bash

# IPCrawler - Penetration Testing IP Analysis Tool
# Quick build and run script

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${BLUE}[IPCrawler]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[IPCrawler]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[IPCrawler]${NC} $1"
}

print_error() {
    echo -e "${RED}[IPCrawler]${NC} $1"
}

print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

# Check if Go is installed
if ! command -v go &> /dev/null; then
    print_error "Go is not installed. Please run ./ipcrawler-installer first."
    exit 1
fi

# Check if we're in the correct directory
if [[ ! -f "main.go" ]]; then
    print_error "main.go not found. Please run this script from the project root directory."
    exit 1
fi

# Check if dependencies exist, if not suggest running installer
if [[ ! -f "go.sum" ]]; then
    print_warning "Dependencies not found. Running installer is recommended."
    print_info "Please run: ./ipcrawler-installer"
    exit 1
fi

print_status "Building IPCrawler..."

# Create bin directory if it doesn't exist
mkdir -p bin

# Only remove the binary, not the entire cache
if [[ -f "bin/ipcrawler" ]]; then
    rm -f bin/ipcrawler
fi

# Build the application (dependencies should already be downloaded)
if go build -o bin/ipcrawler .; then
    print_success "Build successful!"
    
    # Verify the binary was created
    if [[ -f "bin/ipcrawler" ]]; then
        print_success "Starting IPCrawler TUI..."
        echo ""
        
        # Run the application
        ./bin/ipcrawler
    else
        print_error "Binary not found after build!"
        exit 1
    fi
else
    print_error "Build failed!"
    print_warning "If this persists, try running: ./ipcrawler-installer"
    exit 1
fi 